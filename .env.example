# Firebase — solo obligatorio para Web y Linux/Windows/macOS (Dart lee estas claves).
# En Android e iOS la app usa google-services.json / GoogleService-Info.plist
# y puedes ejecutar `flutter run` sin este archivo.
#
# Web / escritorio:
#   flutter run -d chrome --dart-define-from-file=.env
#   flutter build linux --dart-define-from-file=.env
#
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

FIREBASE_WEB_API_KEY=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_AUTH_DOMAIN=
# Opcional (Analytics)
FIREBASE_WEB_MEASUREMENT_ID=
